---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SEO from "../components/SEO.astro";
---

<html lang="es" class="scroll-smooth">
	<head>
		<SEO />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap"
			rel="stylesheet"
		/>

		<!-- Theme toggle script -->
		<script is:inline>
			const theme = (() => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			})();

			if (theme === "dark") {
				document.documentElement.classList.add("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
			window.localStorage.setItem("theme", theme);
		</script>
	</head>
	<body
		class="relative text-slate-900 bg-slate-50 dark:text-white dark:bg-slate-950 selection:bg-purple-200 dark:selection:bg-purple-900 selection:text-purple-900 dark:selection:text-white overflow-x-hidden transition-colors duration-300"
	>
		<!-- Background Blobs -->
		<div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
			<div
				class="blob blob-light-purple dark:blob-purple w-[500px] h-[500px] -top-[200px] -left-[100px]"
			>
			</div>
			<div
				class="blob blob-light-fuchsia dark:blob-fuchsia w-[600px] h-[600px] top-[40%] -right-[200px]"
			>
			</div>
			<div
				class="blob blob-light-purple dark:blob-purple w-[800px] h-[400px] top-[70%] left-[10%] opacity-20"
			>
			</div>
		</div>

		<!-- Full-screen Overlay Menu -->
		<div
			id="overlayMenu"
			class="fixed inset-0 z-40 bg-slate-50/98 dark:bg-slate-950/98 backdrop-blur-2xl flex items-center translate-y-[-100%] transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] overflow-hidden"
		>
			<div
				class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
			>
				<!-- Left side: Giant navigation links -->
				<div class="space-y-6 md:space-y-8 font-sans">
					<nav class="flex flex-col gap-4 sm:gap-6">
						{
							[
								{ num: "01", text: "INICIO", href: "#" },
								{
									num: "02",
									text: "SERVICIOS",
									href: "#servicios",
								},
								{
									num: "03",
									text: "PROCESO",
									href: "#proceso",
								},
								{
									num: "04",
									text: "TRABAJEMOS JUNTOS",
									href: "#contacto",
								},
							].map((link) => (
								<a
									href={link.href}
									class="menu-link group flex items-baseline gap-4 md:gap-6 text-4xl sm:text-6xl md:text-7xl font-bold tracking-tighter text-slate-800 dark:text-slate-200 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-300"
								>
									<span class="text-lg sm:text-2xl font-serif text-slate-400 dark:text-slate-600 group-hover:text-purple-400 dark:group-hover:text-purple-500 font-medium">
										{link.num}.
									</span>
									<span class="font-sans leading-none uppercase">
										{link.text}
									</span>
								</a>
							))
						}
					</nav>
				</div>

				<!-- Right side: Contact block (Only desktop) -->
				<div
					class="hidden md:flex flex-col justify-center space-y-8 border-l border-slate-200 dark:border-white/5 pl-12 h-96"
				>
					<div class="space-y-2">
						<span
							class="text-xs font-bold tracking-widest text-slate-400 dark:text-slate-600 uppercase"
							>¿Tienes un proyecto en mente?</span
						>
						<a
							href="mailto:hola@guillermoml.com"
							class="block text-2xl font-semibold text-slate-800 dark:text-slate-200 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-300"
						>
							hola@guillermoml.com
						</a>
					</div>

					<div class="flex items-center gap-3">
						<span class="relative flex h-3 w-3">
							<span
								class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
							></span>
							<span
								class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"
							></span>
						</span>
						<span
							class="text-sm font-medium text-slate-600 dark:text-slate-400"
						>
							Disponible para nuevos proyectos.
						</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Navigation Header (Sticky + Backdrop Blur) -->
		<header
			class="sticky top-0 z-50 w-full border-b border-slate-200/50 dark:border-white/5 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-md transition-colors duration-300"
		>
			<nav
				class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center relative"
			>
				<!-- Left: Hamburger Menu Trigger (Active both Mobile & Desktop) -->
				<button
					id="menuToggle"
					class="p-2 focus:outline-none flex flex-col justify-center items-center gap-1.5 w-10 h-10 rounded-full border border-slate-200/60 dark:border-white/10 bg-white/40 dark:bg-slate-900/40 hover:bg-white dark:hover:bg-slate-800 transition-all cursor-pointer z-50"
					aria-label="Toggle menú"
				>
					<span
						id="menuLine1"
						class="w-5 h-[2px] bg-slate-800 dark:bg-slate-200 transition-all duration-300"
					></span>
					<span
						id="menuLine2"
						class="w-5 h-[2px] bg-slate-800 dark:bg-slate-200 transition-all duration-300"
					></span>
				</button>

				<!-- Right: Theme Toggle & Secondary CTA -->
				<div class="flex items-center gap-3 sm:gap-4 z-50">
					<button
						id="themeToggle"
						class="p-2 rounded-full bg-white/50 dark:bg-slate-800/50 backdrop-blur-md border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 hover:bg-white dark:hover:bg-slate-800 transition-all cursor-pointer"
						aria-label="Alternar tema"
					>
						<svg
							id="sunIcon"
							class="w-5 h-5 hidden dark:block"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
							></path></svg
						>
						<svg
							id="moonIcon"
							class="w-5 h-5 block dark:hidden"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
							></path></svg
						>
					</button>

					<a
						href="#contacto"
						class="inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-[12px] sm:text-[13px] font-medium text-purple-600 dark:text-purple-400 hover:text-purple-700 dark:hover:text-purple-300 border border-purple-200 dark:border-purple-800/50 hover:border-purple-300 dark:hover:border-purple-700/80 bg-purple-50/30 dark:bg-purple-950/10 hover:bg-purple-50 dark:hover:bg-purple-950/30 rounded-xl transition-all duration-200 group"
					>
						Cotizar
						<span
							class="inline-block transition-transform duration-200 group-hover:translate-x-0.5"
							>→</span
						>
					</a>
				</div>
			</nav>
		</header>

		<main class="relative z-10">
			<!-- ========================================== -->
			<!-- 1. HERO SECTION (GSAP Pinning & StoryPixel Layout) -->
			<!-- ========================================== -->
			<section
				id="hero-scroll-container"
				class="relative h-screen w-full flex flex-col items-center justify-center overflow-hidden z-10"
			>
				<!-- Pinned Hero Content -->
				<div
					id="hero-content"
					class="relative z-20 flex flex-col items-center text-center px-4 max-w-7xl !-top-16 sm:!-top-32 transition-all duration-500"
				>
					<!-- Glowing background aura behind massive text -->
					<div
						class="absolute -inset-10 bg-purple-500/10 dark:bg-purple-500/5 rounded-full blur-3xl pointer-events-none -z-10"
					>
					</div>

					<div
						class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-50 dark:bg-purple-500/10 border border-purple-100 dark:border-purple-500/20 text-purple-700 dark:text-purple-300 text-xs font-semibold tracking-widest uppercase mb-6"
					>
						<span
							class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"
						></span>
						HIGH-CONVERSION LANDING PAGES
					</div>

					<!-- Massive typography H1 serif -->
					<h1
						class="font-serif font-extrabold tracking-tight text-5xl sm:text-7xl md:text-8xl lg:text-9xl leading-[1.0] select-none text-slate-900 dark:text-white"
					>
						No es tu producto.<br class="sm:hidden" /> Es <span
							class="italic text-purple-600 dark:text-purple-400 font-serif"
							>tu landing.</span
						>
					</h1>

					<!-- Subheadline centrado de ancho controlado para dos lineas -->
					<p
						class="text-base sm:text-lg md:text-xl text-slate-600 dark:text-slate-400 mt-8 max-w-3xl leading-relaxed mx-auto"
					>
						Diseño y programo páginas de alta conversión para
						negocios digitales que buscan escalar. Sin plantillas
						pesadas, sin código lento. Solo rendimiento puro.
					</p>

					<!-- CTA Principal -->
					<div class="mt-8 flex justify-center">
						<a
							href="#contacto"
							class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-purple-600 hover:bg-purple-700 dark:bg-purple-500 dark:hover:bg-purple-600 rounded-xl transition-all shadow-[0_0_20px_rgba(147,51,234,0.3)] hover:shadow-[0_0_30px_rgba(147,51,234,0.5)] transform hover:-translate-y-0.5 duration-200"
						>
							Optimizar mi landing page →
						</a>
					</div>
				</div>

				<!-- Floating Bento-style interface cards -->
				<div
					id="floating-cards-container"
					class="absolute inset-0 z-30 pointer-events-none"
				>
					<!-- Card 1: Metrics Glassmorphic Card (Peeks at the bottom on initial load - CRO Open Loop) -->
					<div
						class="bento-card-wrapper absolute w-[280px] sm:w-[340px] will-change-transform"
						style="top: 86%; left: 8%;"
					>
						<div
							class="bento-card glass-card rounded-2xl p-5 shadow-2xl border border-purple-500/20 dark:border-white/10 will-change-transform"
						>
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center gap-1.5">
									<div
										class="w-2.5 h-2.5 rounded-full bg-red-400/80"
									>
									</div>
									<div
										class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"
									>
									</div>
									<div
										class="w-2.5 h-2.5 rounded-full bg-green-400/80"
									>
									</div>
								</div>
								<span
									class="text-[9px] uppercase font-bold tracking-widest text-purple-600 dark:text-purple-400 font-sans"
									>Conversión</span
								>
							</div>
							<div class="space-y-3">
								<div class="flex justify-between items-end">
									<span
										class="text-xs text-slate-500 font-sans"
										>Tasa de conversión</span
									>
									<span
										class="text-2xl font-bold font-mono text-slate-800 dark:text-white leading-none"
										>+142%</span
									>
								</div>
								<div
									class="w-full bg-slate-100 dark:bg-slate-800/80 h-2 rounded-full overflow-hidden"
								>
									<div
										class="bg-gradient-to-r from-purple-500 to-fuchsia-500 h-full rounded-full w-[85%]"
									>
									</div>
								</div>
								<p class="text-[9px] text-slate-500 font-sans">
									Auditoría UX y optimización de CTAs
									completada
								</p>
							</div>
						</div>
					</div>

					<!-- Card 2: A/B Test Champion Card -->
					<div
						class="bento-card-wrapper absolute w-[260px] sm:w-[320px] will-change-transform"
						style="top: 108%; right: 6%;"
					>
						<div
							class="bento-card glass-card rounded-2xl p-5 shadow-2xl border border-emerald-500/20 dark:border-white/10 will-change-transform"
						>
							<div class="flex justify-between items-start mb-4">
								<div>
									<h4
										class="text-xs font-bold text-slate-800 dark:text-white font-sans"
									>
										A/B Test Champion
									</h4>
									<p
										class="text-[9px] text-slate-500 font-sans"
									>
										Estructura de Hero optimizada
									</p>
								</div>
								<span
									class="px-2 py-0.5 text-[8px] font-bold bg-emerald-100 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-300 rounded-full font-sans"
									>GANADOR</span
								>
							</div>
							<div class="space-y-3 font-sans">
								<!-- Option A (Control) -->
								<div class="space-y-1">
									<div
										class="flex justify-between text-[9px] text-slate-500"
									>
										<span>Versión A (Original)</span>
										<span class="font-mono">1.8% CR</span>
									</div>
									<div
										class="w-full bg-slate-100 dark:bg-slate-800/80 h-1.5 rounded-full overflow-hidden"
									>
										<div
											class="bg-slate-400 dark:bg-slate-600 h-full w-[35%]"
										>
										</div>
									</div>
								</div>
								<!-- Option B (Guillermo Moreno) -->
								<div class="space-y-1">
									<div
										class="flex justify-between text-[9px] text-slate-800 dark:text-white font-semibold"
									>
										<span>Versión B (Guillermo)</span>
										<span class="font-mono text-emerald-500"
											>4.6% CR</span
										>
									</div>
									<div
										class="w-full bg-slate-100 dark:bg-slate-800/80 h-1.5 rounded-full overflow-hidden"
									>
										<div
											class="bg-gradient-to-r from-emerald-500 to-teal-500 h-full w-[90%]"
										>
										</div>
									</div>
								</div>
								<p
									class="text-[8px] text-slate-400 dark:text-slate-500 border-t border-slate-100 dark:border-white/5 pt-2 mt-1"
								>
									Nivel de confianza: 99.9% (Significativo)
								</p>
							</div>
						</div>
					</div>

					<!-- Card 3: Performance Audit Tool Card -->
					<div
						class="bento-card-wrapper absolute w-[280px] sm:w-[360px] will-change-transform"
						style="top: 132%; left: 24%;"
					>
						<div
							class="bento-card glass-card rounded-2xl p-5 shadow-2xl border border-indigo-500/20 dark:border-white/10 will-change-transform"
						>
							<div class="flex items-center gap-4 mb-4">
								<div
									class="w-12 h-12 rounded-full border-4 border-emerald-500/30 border-t-emerald-500 flex items-center justify-center text-sm font-mono font-bold text-emerald-500"
								>
									99
								</div>
								<div>
									<h4
										class="text-xs font-bold text-slate-800 dark:text-white font-sans"
									>
										Performance Score
									</h4>
									<p
										class="text-[9px] text-slate-500 font-sans"
									>
										Google Lighthouse auditado
									</p>
								</div>
							</div>
							<div class="grid grid-cols-3 gap-2 font-sans">
								<div
									class="bg-slate-100/50 dark:bg-slate-900/50 p-2 rounded-lg text-center border border-slate-200/20 dark:border-white/5"
								>
									<span
										class="block text-[8px] text-slate-400"
										>FCP</span
									>
									<span
										class="text-xs font-mono font-bold text-slate-700 dark:text-slate-300"
										>0.4s</span
									>
								</div>
								<div
									class="bg-slate-100/50 dark:bg-slate-900/50 p-2 rounded-lg text-center border border-slate-200/20 dark:border-white/5"
								>
									<span
										class="block text-[8px] text-slate-400"
										>LCP</span
									>
									<span
										class="text-xs font-mono font-bold text-slate-700 dark:text-slate-300"
										>0.8s</span
									>
								</div>
								<div
									class="bg-slate-100/50 dark:bg-slate-900/50 p-2 rounded-lg text-center border border-slate-200/20 dark:border-white/5"
								>
									<span
										class="block text-[8px] text-slate-400"
										>CLS</span
									>
									<span
										class="text-xs font-mono font-bold text-slate-700 dark:text-slate-300"
										>0.01</span
									>
								</div>
							</div>
						</div>
					</div>

					<!-- Card 4: Leads Chart Tracker Card -->
					<div
						class="bento-card-wrapper absolute w-[240px] sm:w-[300px] will-change-transform"
						style="top: 154%; right: 26%;"
					>
						<div
							class="bento-card glass-card rounded-2xl p-5 shadow-2xl border border-purple-500/20 dark:border-white/10 will-change-transform"
						>
							<div class="flex justify-between items-center mb-4">
								<span
									class="text-xs font-bold text-slate-800 dark:text-white font-sans"
									>Leads Captados</span
								>
								<span
									class="text-xs font-mono font-bold text-emerald-500"
									>+84%</span
								>
							</div>
							<div class="h-16 flex items-end gap-1.5 w-full">
								<div
									class="bg-purple-100 dark:bg-purple-900/30 h-[30%] w-full rounded-t"
								>
								</div>
								<div
									class="bg-purple-100 dark:bg-purple-900/30 h-[45%] w-full rounded-t"
								>
								</div>
								<div
									class="bg-purple-200 dark:bg-purple-800/30 h-[35%] w-full rounded-t"
								>
								</div>
								<div
									class="bg-purple-300 dark:bg-purple-700/30 h-[60%] w-full rounded-t"
								>
								</div>
								<div
									class="bg-purple-400 dark:bg-purple-600/30 h-[50%] w-full rounded-t"
								>
								</div>
								<div
									class="bg-purple-500 h-[80%] w-full rounded-t shadow-[0_0_10px_rgba(168,85,247,0.4)]"
								>
								</div>
								<div
									class="bg-fuchsia-500 h-[95%] w-full rounded-t shadow-[0_0_12px_rgba(217,70,239,0.4)]"
								>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ========================================== -->
			<!-- 2. PRUEBA SOCIAL / AUTORIDAD               -->
			<!-- ========================================== -->
			<section
				class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 border-y border-slate-200/50 dark:border-white/5"
			>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16">
					<!-- Columna 1: Experiencia -->
					<div
						class="flex flex-col items-center md:items-start space-y-3"
					>
						<span
							class="font-serif font-extrabold text-5xl md:text-6xl bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-fuchsia-500 dark:from-purple-400 dark:to-fuchsia-400 leading-none select-none"
						>
							5+ años
						</span>
						<span
							class="font-sans text-sm md:text-base text-slate-500 dark:text-slate-400 leading-relaxed text-center md:text-left max-w-[24ch]"
						>
							diseñando interfaces de alto rendimiento.
						</span>
					</div>

					<!-- Columna 2: Escala -->
					<div
						class="flex flex-col items-center md:items-start space-y-3"
					>
						<span
							class="font-serif font-extrabold text-5xl md:text-6xl bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-fuchsia-500 dark:from-purple-400 dark:to-fuchsia-400 leading-none select-none"
						>
							7.7M+
						</span>
						<span
							class="font-sans text-sm md:text-base text-slate-500 dark:text-slate-400 leading-relaxed text-center md:text-left max-w-[28ch]"
						>
							Usuarios activos en más de 170 países interactuando
							con mi diseño.
