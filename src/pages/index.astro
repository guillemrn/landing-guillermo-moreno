		<script is:inline>
			// Theme Toggle Logic
			const themeToggleBtn = document.getElementById("themeToggle");

			themeToggleBtn.addEventListener("click", () => {
				const isDark =
					document.documentElement.classList.toggle("dark");
				localStorage.setItem("theme", isDark ? "dark" : "light");
			});
		</script>

		<!-- Interactive GSAP & Full-screen Overlay Script -->
		<script>
			import { gsap } from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";

			gsap.registerPlugin(ScrollTrigger);

			// 1. Full-screen Overlay Menu Logic
			const menuToggle = document.getElementById("menuToggle");
			const overlayMenu = document.getElementById("overlayMenu");
			const menuLine1 = document.getElementById("menuLine1");
			const menuLine2 = document.getElementById("menuLine2");
			let isOpen = false;

			function toggleMenu() {
				isOpen = !isOpen;
				if (isOpen) {
					overlayMenu.classList.remove("translate-y-[-100%]");
					overlayMenu.classList.add("translate-y-0");
					menuLine1.classList.add("rotate-45", "translate-y-[4px]");
					menuLine2.classList.add("-rotate-45", "-translate-y-[4px]");
					document.body.style.overflow = "hidden";
				} else {
					overlayMenu.classList.remove("translate-y-0");
					overlayMenu.classList.add("translate-y-[-100%]");
					menuLine1.classList.remove(
						"rotate-45",
						"translate-y-[4px]",
					);
					menuLine2.classList.remove(
						"-rotate-45",
						"-translate-y-[4px]",
					);
					document.body.style.overflow = "";
				}
			}

			if (menuToggle && overlayMenu && menuLine1 && menuLine2) {
				menuToggle.addEventListener("click", toggleMenu);

				const menuLinks = document.querySelectorAll(".menu-link");
				menuLinks.forEach((link) => {
					link.addEventListener("click", () => {
						if (isOpen) toggleMenu();
					});
				});
			}

			// 2. GSAP Pinning & Parallax Bento Cards Anim
			const heroScrollContainer = document.getElementById(
				"hero-scroll-container",
			);
			if (heroScrollContainer) {
				const tl = gsap.timeline({
					scrollTrigger: {
						trigger: "#hero-scroll-container",
						start: "top top",
						end: "+=180%", // Pinned scroll length
						pin: true,
						scrub: 1.5, // 1.5s fluid deceleration momentum drift
					},
				});

				// Bento Card Wrappers parallax floats upward from bottom
				tl.to(
					".bento-card-wrapper",
					{
						y: (index) => {
							const speeds = [-800, -1100, -1400, -1700];
							return speeds[index];
						},
						rotate: (index) => {
							const rotations = [-6, 5, -5, 6];
							return rotations[index];
						},
						stagger: 0.05,
						ease: "power1.out", // Decelerates softly
					},
					0,
				);

				// Subtle fading and scale out of H1 content as cards overlay
				tl.to(
					"#hero-content",
					{
						opacity: 0.15,
						scale: 0.94,
						filter: "blur(5px)",
						ease: "none",
					},
					0.25,
				);

				// 3. Infinite Gentle Organic Floating/Breathing Animation
				gsap.utils.toArray(".bento-card").forEach((card, index) => {
					gsap.to(card, {
						y: "random(-12, 12)", // Slow vertical sway
						x: "random(-6, 6)", // Slow horizontal sway
						rotate: "random(-2, 2)", // Soft angle sway
						duration: "random(4.5, 6)", // Randomized asymmetric cycle
						repeat: -1,
						yoyo: true,
						ease: "sine.inOut",
						delay: index * 0.35, // Natural entry delay
					});
				});
			}

			// 4. Form Context Handler: select corresponding service option in dropdown on CTA click
			const serviceLinks = document.querySelectorAll("[data-service]");
			serviceLinks.forEach((link) => {
				link.addEventListener("click", () => {
					const serviceVal = link.getAttribute("data-service");
					const selectElement = document.getElementById("objetivo");
					if (selectElement && serviceVal) {
						selectElement.value = serviceVal;
					}
				});
			});
		</script>
