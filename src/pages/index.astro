---
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Guillermo Moreno | Product Design Studio</title>
		<meta name="description" content="Diseño y programo experiencias e infraestructura digital de alto rendimiento enfocadas en convertir visitas en clientes." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" rel="stylesheet">
		
		<!-- Theme toggle script -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="relative text-slate-900 bg-slate-50 dark:text-white dark:bg-slate-950 selection:bg-purple-200 dark:selection:bg-purple-900 selection:text-purple-900 dark:selection:text-white overflow-x-hidden transition-colors duration-300">
		
		<!-- Background Blobs -->
		<div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
			<div class="blob blob-light-purple dark:blob-purple w-[500px] h-[500px] -top-[200px] -left-[100px]"></div>
			<div class="blob blob-light-fuchsia dark:blob-fuchsia w-[600px] h-[600px] top-[40%] -right-[200px]"></div>
			<div class="blob blob-light-purple dark:blob-purple w-[800px] h-[400px] top-[70%] left-[10%] opacity-20"></div>
		</div>

		<!-- Navigation (Theme Toggle) -->
		<nav class="relative z-50 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex justify-between items-center">
			<div class="flex items-center gap-2">
				<div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-500/20 text-purple-600 dark:text-purple-400 flex items-center justify-center font-serif font-bold text-sm ring-1 ring-purple-200 dark:ring-purple-500/30">
					GM
				</div>
				<span class="font-medium text-sm tracking-wide dark:text-slate-200">Guillermo Moreno</span>
			</div>
			
			<button id="themeToggle" class="p-2 rounded-full bg-white/50 dark:bg-slate-800/50 backdrop-blur-md border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 hover:bg-white dark:hover:bg-slate-800 transition-all cursor-pointer" aria-label="Alternar tema">
				<svg id="sunIcon" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
				<svg id="moonIcon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
			</button>
		</nav>

		<main class="relative z-10">
			
			<!-- ========================================== -->
			<!-- 1. HERO SECTION                            -->
			<!-- ========================================== -->
			<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-8 items-center">
					<div class="space-y-8 max-w-2xl">
						<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-50 dark:bg-purple-500/10 border border-purple-100 dark:border-purple-500/20 text-purple-700 dark:text-purple-300 text-xs font-semibold tracking-widest uppercase">
							<span class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
							Diseño • UX • Conversión
						</div>
						
						<h1 class="font-serif text-5xl md:text-6xl lg:text-7xl leading-[1.1] tracking-tight">
							No es tu producto.<br/>Es <span class="italic text-purple-600 dark:text-purple-400">tu landing.</span>
						</h1>
						
						<p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed max-w-[50ch]">
							Diseño páginas y experiencias enfocadas en atraer, conectar y convertir visitantes en clientes para hacer crecer tu negocio.
						</p>
						
						<div class="flex flex-col sm:flex-row gap-4 pt-4">
							<a href="#contacto" class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-purple-600 hover:bg-purple-700 dark:bg-purple-500 dark:hover:bg-purple-600 rounded-xl transition-all shadow-[0_0_20px_rgba(147,51,234,0.3)] hover:shadow-[0_0_30px_rgba(147,51,234,0.5)]">
								Optimizar mi conversión
								<svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</a>
						</div>
					</div>

					<div class="relative h-[400px] md:h-[500px] w-full perspective-1000">
						<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[450px] glass-card rounded-2xl p-6 z-20 shadow-2xl">
							<div class="flex items-center gap-2 mb-6">
								<div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-slate-700"></div>
								<div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-slate-700"></div>
								<div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-slate-700"></div>
							</div>
							<div class="space-y-4">
								<div class="h-4 w-1/3 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
								<div class="h-4 w-1/2 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
								<div class="mt-8 aspect-video rounded-xl bg-gradient-to-tr from-purple-100 to-purple-50 dark:from-purple-900/40 dark:to-purple-800/20 border border-purple-200 dark:border-purple-700/50 flex items-end overflow-hidden p-4">
									<svg class="w-full h-full text-purple-500 dark:text-purple-400 drop-shadow-[0_0_8px_rgba(168,85,247,0.5)]" viewBox="0 0 100 40" preserveAspectRatio="none">
										<path d="M0 40 L0 30 Q 15 25, 25 35 T 50 20 T 75 10 T 100 5 L100 40 Z" fill="currentColor" fill-opacity="0.2"/>
										<path d="M0 30 Q 15 25, 25 35 T 50 20 T 75 10 T 100 5" fill="none" stroke="currentColor" stroke-width="2"/>
										<circle cx="100" cy="5" r="2" fill="currentColor"/>
									</svg>
								</div>
								<div class="h-10 w-1/3 bg-purple-600 dark:bg-purple-500 rounded-lg mt-4 shadow-[0_0_15px_rgba(168,85,247,0.4)]"></div>
							</div>
						</div>
						<div class="absolute top-10 right-0 lg:-right-10 w-64 glass-card rounded-xl p-5 z-10 opacity-80 blur-[1px] transform rotate-3">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 rounded-full border-4 border-purple-200 dark:border-purple-800/50 border-t-purple-500 dark:border-t-purple-400"></div>
								<div class="space-y-2 flex-1">
									<div class="h-3 w-full bg-slate-200 dark:bg-slate-700 rounded-full"></div>
									<div class="h-3 w-2/3 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
								</div>
							</div>
						</div>
						<div class="absolute bottom-10 left-0 lg:-left-10 w-72 glass-card rounded-xl p-5 z-30 opacity-90 transform -rotate-2">
							<div class="space-y-3">
								<div class="flex gap-2">
									<div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-500/20"></div>
									<div class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800"></div>
									<div class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800"></div>
								</div>
								<div class="h-2 w-full bg-slate-200 dark:bg-slate-700 rounded-full"></div>
								<div class="h-2 w-full bg-slate-200 dark:bg-slate-700 rounded-full"></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ========================================== -->
			<!-- 2. PRUEBA SOCIAL / AUTORIDAD               -->
			<!-- ========================================== -->
			<section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16 border-y border-slate-200/50 dark:border-white/5">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16">
					<div class="flex flex-col items-center md:items-start space-y-2">
						<span class="font-serif text-5xl md:text-6xl text-slate-900 dark:text-white leading-none">42K+</span>
						<span class="text-xs text-slate-500 dark:text-slate-400 font-bold uppercase tracking-wider text-center md:text-left">
							Usuarios activos en productos diseñados
						</span>
					</div>
					<div class="flex flex-col items-center md:items-start space-y-2">
						<span class="font-serif text-5xl md:text-6xl text-purple-600 dark:text-purple-400 leading-none">+100%</span>
						<span class="text-xs text-slate-500 dark:text-slate-400 font-bold uppercase tracking-wider text-center md:text-left">
							De incremento promedio en conversión
						</span>
					</div>
				</div>
			</section>

			<!-- ========================================== -->
			<!-- 3. AGITACIÓN DE LA FRICCIÓN (El Problema)  -->
			<!-- ========================================== -->
			<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
				<div class="glass-card rounded-3xl p-8 md:p-16 flex flex-col md:flex-row gap-12 items-center">
					<div class="md:w-1/2 space-y-6">
						<span class="text-sm font-bold tracking-widest text-red-500 dark:text-red-400 uppercase">El Problema</span>
						<h2 class="font-serif text-4xl leading-tight">
							El mejor producto del mundo no se vende solo.
						</h2>
						<p class="text-lg text-slate-600 dark:text-slate-400">
							Tener un excelente servicio no sirve de nada si tu sitio web funciona como un muro entre tú y tus clientes. Si te identificas con esto, estás perdiendo dinero:
						</p>
					</div>
					
					<div class="md:w-1/2 w-full">
						<ul class="space-y-6">
							{[
								{ icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Diseño que no comunica valor', text: 'Tus visitantes no entienden qué haces en los primeros 5 segundos y se van a la competencia.' },
								{ icon: 'M13 17h8m0 0V9m0 8l-8-8-4 4-6-6', title: 'Flujos confusos y CTAs invisibles', text: 'La experiencia es tan compleja que los usuarios abandonan antes de contactarte o comprar.' },
								{ icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Velocidad de carga lenta', text: 'Tu landing tarda demasiado en cargar por deuda técnica, matando tu SEO y conversiones.' },
							].map((item) => (
								<li class="flex gap-4">
									<div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0 text-slate-500 dark:text-slate-400">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}></path>
										</svg>
									</div>
									<div>
										<h4 class="font-bold text-slate-900 dark:text-white">{item.title}</h4>
										<p class="text-sm text-slate-600 dark:text-slate-400 mt-1">{item.text}</p>
									</div>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>

			<!-- ========================================== -->
			<!-- 4. OFERTA CORE (Servicios Estandarizados)  -->
			<!-- ========================================== -->
			<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
				<div class="text-center space-y-4 mb-16">
					<span class="text-sm font-bold tracking-widest text-purple-600 dark:text-purple-400 uppercase">Soluciones</span>
					<h2 class="font-serif text-4xl md:text-5xl leading-tight">
						Diseño estratégico para<br/>negocios que quieren <span class="italic text-purple-600 dark:text-purple-400">crecer.</span>
					</h2>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					
					<!-- Card 1 -->
					<div class="glass-card glass-card-hover rounded-3xl p-8 flex flex-col relative overflow-hidden group">
						<div class="absolute top-0 right-0 w-48 h-48 bg-purple-500/10 rounded-full blur-3xl group-hover:bg-purple-500/20 transition-all"></div>
						
						<div class="relative z-10 flex flex-col h-full">
							<div class="w-12 h-12 rounded-2xl bg-purple-50 dark:bg-purple-500/10 flex items-center justify-center text-purple-600 dark:text-purple-400 mb-6">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
							</div>
							
							<div class="space-y-4 flex-grow">
								<h3 class="font-serif text-2xl md:text-3xl">Auditoría UX y <span class="italic">Conversión.</span></h3>
								<p class="text-slate-600 dark:text-slate-400 text-sm">Detectamos fricción, problemas y oportunidades para mejorar la experiencia inmediatamente.</p>
								
								<ul class="space-y-3 pt-4 border-t border-slate-200 dark:border-white/5">
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-purple-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Análisis heurístico profundo
									</li>
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-purple-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Identificación de fugas
									</li>
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-purple-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Recomendaciones accionables
									</li>
								</ul>
							</div>
							
							<div class="pt-8 mt-8 border-t border-slate-200 dark:border-white/10">
								<a href="#contacto" class="flex justify-center items-center w-full px-6 py-3 border border-purple-200 dark:border-purple-700/50 text-purple-600 dark:text-purple-300 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-xl transition-colors font-medium">
									Solicitar auditoría
								</a>
							</div>
						</div>
					</div>

					<!-- Card 2 -->
					<div class="glass-card glass-card-hover rounded-3xl p-8 flex flex-col relative overflow-hidden group">
						<div class="absolute top-0 right-0 w-48 h-48 bg-fuchsia-500/10 rounded-full blur-3xl group-hover:bg-fuchsia-500/20 transition-all"></div>
						
						<div class="relative z-10 flex flex-col h-full">
							<div class="w-12 h-12 rounded-2xl bg-fuchsia-50 dark:bg-fuchsia-500/10 flex items-center justify-center text-fuchsia-600 dark:text-fuchsia-400 mb-6">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
							</div>
							
							<div class="space-y-4 flex-grow">
								<h3 class="font-serif text-2xl md:text-3xl">Landing Pages <span class="italic">que convierten.</span></h3>
								<p class="text-slate-600 dark:text-slate-400 text-sm">Páginas de alta conversión con diseño claro, persuasivo y adaptadas a móvil.</p>
								
								<ul class="space-y-3 pt-4 border-t border-slate-200 dark:border-white/5">
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-fuchsia-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Estrategia de conversión
									</li>
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-fuchsia-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Diseño de alto contraste
									</li>
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-fuchsia-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Optimización de velocidad
									</li>
								</ul>
							</div>
							
							<div class="pt-8 mt-8 border-t border-slate-200 dark:border-white/10">
								<a href="#contacto" class="flex justify-center items-center w-full px-6 py-3 border border-fuchsia-200 dark:border-fuchsia-700/50 text-fuchsia-600 dark:text-fuchsia-300 hover:bg-fuchsia-50 dark:hover:bg-fuchsia-900/20 rounded-xl transition-colors font-medium">
									Cotizar landing page
								</a>
							</div>
						</div>
					</div>

					<!-- Card 3 -->
					<div class="glass-card glass-card-hover rounded-3xl p-8 flex flex-col relative overflow-hidden group">
						<div class="absolute top-0 right-0 w-48 h-48 bg-indigo-500/10 rounded-full blur-3xl group-hover:bg-indigo-500/20 transition-all"></div>
						
						<div class="relative z-10 flex flex-col h-full">
							<div class="w-12 h-12 rounded-2xl bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-6">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
							</div>
							
							<div class="space-y-4 flex-grow">
								<h3 class="font-serif text-2xl md:text-3xl">Sistemas de <span class="italic">Automatización.</span></h3>
								<p class="text-slate-600 dark:text-slate-400 text-sm">Automatizo procesos comerciales para que ahorres tiempo, escales y vendas más.</p>
								
								<ul class="space-y-3 pt-4 border-t border-slate-200 dark:border-white/5">
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-indigo-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Integración con CRMs
									</li>
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-indigo-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Secuencias de email
									</li>
									<li class="flex text-sm text-slate-700 dark:text-slate-300">
										<svg class="w-4 h-4 text-indigo-500 mr-2 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
										Automatización de WhatsApp
									</li>
								</ul>
							</div>
							
							<div class="pt-8 mt-8 border-t border-slate-200 dark:border-white/10">
								<a href="#contacto" class="flex justify-center items-center w-full px-6 py-3 text-white bg-purple-600 hover:bg-purple-700 dark:bg-purple-500 dark:hover:bg-purple-600 rounded-xl transition-all shadow-[0_0_15px_rgba(147,51,234,0.3)] font-medium">
									Solicitar sistema
								</a>
							</div>
						</div>
					</div>

				</div>
			</section>

			<!-- ========================================== -->
			<!-- 5. ROADMAP DEL PROCESO                     -->
			<!-- ========================================== -->
			<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
				<div class="text-center space-y-4 mb-16">
					<h2 class="font-serif text-4xl md:text-5xl leading-tight">
						Cómo funciona el <span class="italic text-purple-600 dark:text-purple-400">proceso.</span>
					</h2>
